// Implementação de um método chamado classificarCampanha que recebe três valores de doação, do tipo double, e retorna uma String com a classificação da 
campanha. O método soma os três valores recebidos. Se o total arrecadado for maior ou igual a 500.0, retorna Campanha de grande impacto. Se o total
for maior ou igual a 200.0 e menor que 500.0, retorna Campanha de médio impacto. Caso contrário, retorna Campanha de pequeno impacto.

import java.util.Scanner;


public class Campanha {

    private double doacao1;
    private double doacao2;
    private double doacao3;

    public Campanha(double doacao1, double doacao2, double doacao3) {
        this.doacao1 = doacao1;
        this.doacao2 = doacao2;
        this.doacao3 = doacao3;
    }

    public double getTotalArrecadado() {
        return this.doacao1 + this.doacao2 + this.doacao3;
    }

    public String classificarImpacto() {
        double total = getTotalArrecadado(); 

        if (total >= 500.0) {
            return "Campanha de grande impacto";
        } else if (total >= 200.0) {
            return "Campanha de médio impacto";
        } else {
            return "Campanha de pequeno impacto";
        }
    }
}


class Main {

    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);

        double d1 = input.nextDouble();
        double d2 = input.nextDouble();
        double d3 = input.nextDouble();

        // Cria o objeto passando os dados brutos
        Campanha x = new Campanha(d1, d2, d3);

        System.out.println("Total arrecadado: " + x.getTotalArrecadado());
        System.out.println("Classificação: " + x.classificarImpacto());
        
    }
}
